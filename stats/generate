#!/bin/bash

. "${BASH_SOURCE%/*}"/"../utils/table_align"
. "${BASH_SOURCE%/*}/../themes/filter"

DB_FILE="${BASH_SOURCE%/*}"/"../puzzfinder.db"
STATS_FILE="${BASH_SOURCE%/*}"/"STATS.md"

TOTAL=$(duckdb -csv "$DB_FILE" "SELECT COUNT(*) FROM puzzles;" | tail -1)

union_query=""
for theme in "${THEMES[@]}"; do
	part="SELECT '$theme' AS theme, COUNT(*) AS cnt FROM puzzles WHERE $(theme_filter "$theme")"
	union_query+="${union_query:+ UNION ALL }$part"
done

ROWS=$(duckdb -csv "$DB_FILE" "SELECT theme, cnt FROM ($union_query) ORDER BY cnt DESC;" | tail -n +2)

{
	echo "# Theme Statistics"
	echo ""
	echo "Total puzzles: **$(printf "%'.f" "$TOTAL")**"
	echo ""
	echo "| #  | Theme | Count | % of puzzles |"
	echo "| -- | ----- | ----- | ------------ |"

	rank=1
	while IFS=',' read -r theme count; do
		pct=$(awk -v c="$count" -v t="$TOTAL" 'BEGIN { printf "%.1f%%", c / t * 100 }')
		count_fmt=$(printf "%'.f" "$count")
		printf "| %d | %s | %s | %s |\n" "$rank" "$theme" "$count_fmt" "$pct"
		((rank++))
	done <<< "$ROWS"
} > "$STATS_FILE"

table_align "$STATS_FILE"

echo "STATS.md written"
