#!/bin/bash

. "${BASH_SOURCE%/*}/lib/core"

ROOT="${BASH_SOURCE%/*}/.."
DB_FILE="$ROOT/puzzfinder.db"
RUNS="${1:-5}"

declare -a ROWS

echo "Running $RUNS iterations per query"
echo

# direct lookup
. "${BASH_SOURCE%/*}/groups/get_by_id"

# unfiltered
. "${BASH_SOURCE%/*}/groups/no_filters"
. "${BASH_SOURCE%/*}/groups/sort"

# single filter
. "${BASH_SOURCE%/*}/groups/rating"
. "${BASH_SOURCE%/*}/groups/moves"
. "${BASH_SOURCE%/*}/groups/popularity"
. "${BASH_SOURCE%/*}/groups/theme"
. "${BASH_SOURCE%/*}/groups/themes"

# combined filters
. "${BASH_SOURCE%/*}/groups/rating_and_moves"
. "${BASH_SOURCE%/*}/groups/rating_and_popularity"
. "${BASH_SOURCE%/*}/groups/theme_and_rating"
. "${BASH_SOURCE%/*}/groups/theme_and_moves"
. "${BASH_SOURCE%/*}/groups/theme_and_popularity"

DUCKDB_VERSION=$(duckdb --version | awk '{print $1}')

{
	echo "# Benchmarks"
	echo ""
	echo "_${RUNS} iterations · DuckDB ${DUCKDB_VERSION}_"
	echo ""
	echo "| Group | Query | ms avg |"
	echo "| ----- | ----- | ------ |"
	printf '%s\n' "${ROWS[@]}"
} > "$ROOT/BENCHMARKS.md"

"${BASH_SOURCE%/*}/../utils/table_align" "$ROOT/BENCHMARKS.md"

echo
echo "BENCHMARKS.md written"
