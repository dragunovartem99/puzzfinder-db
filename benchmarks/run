#!/bin/bash

. "${BASH_SOURCE%/*}"/"kit"
. "${BASH_SOURCE%/*}"/"../utils/table_align"
. "${BASH_SOURCE%/*}"/"../themes/filter"

ROOT="${BASH_SOURCE%/*}"/".."
DB_FILE="${BASH_SOURCE%/*}"/"../puzzfinder.db"
RUNS="${1:-5}"

declare -a ROWS

echo "Running $RUNS iterations per query"
echo

# direct access
. "${BASH_SOURCE%/*}"/"suites/get_by_id"

# no filters
. "${BASH_SOURCE%/*}"/"suites/no_filters"

# one theme
. "${BASH_SOURCE%/*}"/"suites/one_theme_common"
. "${BASH_SOURCE%/*}"/"suites/one_theme_uncommon"

# two themes
. "${BASH_SOURCE%/*}"/"suites/two_themes_common"
. "${BASH_SOURCE%/*}"/"suites/two_themes_uncommon"
. "${BASH_SOURCE%/*}"/"suites/two_themes_mixed"

# three themes
. "${BASH_SOURCE%/*}"/"suites/three_themes_common"
. "${BASH_SOURCE%/*}"/"suites/three_themes_uncommon"
. "${BASH_SOURCE%/*}"/"suites/three_themes_mixed"

# rating filter
. "${BASH_SOURCE%/*}"/"suites/rating_common"
. "${BASH_SOURCE%/*}"/"suites/rating_uncommon"

DUCKDB_VERSION=$(duckdb --version | awk '{print $1}')

{
	echo "# Benchmarks"
	echo ""
	echo "_${RUNS} iterations · DuckDB ${DUCKDB_VERSION}_"
	echo ""
	echo "> **mixed** — common and uncommon themes combined"
	echo ""
	echo "| Group | Case | ms avg |"
	echo "| ----- | ---- | ------ |"
	printf '%s\n' "${ROWS[@]}"
} > "$ROOT/BENCHMARKS.md"

table_align "$ROOT/BENCHMARKS.md"

echo
echo "BENCHMARKS.md written"
