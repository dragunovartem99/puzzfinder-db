	"SELECT * FROM puzzles WHERE movesNumber = 1 LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles WHERE movesNumber = 1;"

group_header "search: movesNumber = 2 (most common)"
benchmark "search: movesNumber = 2" "page 1" \
	"SELECT * FROM puzzles WHERE movesNumber = 2 LIMIT 20 OFFSET 0;" \
