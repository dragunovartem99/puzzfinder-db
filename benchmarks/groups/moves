group "movesNumber = 1"
pagination "page 1" \
	"SELECT * FROM puzzles WHERE movesNumber = 1 LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles WHERE movesNumber = 1;"

group "movesNumber = 2"
pagination "page 1" \
	"SELECT * FROM puzzles WHERE movesNumber = 2 LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles WHERE movesNumber = 2;"
pagination "sort by rating ASC" \
	"SELECT * FROM puzzles WHERE movesNumber = 2 ORDER BY rating ASC LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles WHERE movesNumber = 2;"
pagination "deep page" \
	"SELECT * FROM puzzles WHERE movesNumber = 2 LIMIT 20 OFFSET 10000;" \
	"SELECT COUNT(*) FROM puzzles WHERE movesNumber = 2;"
