group "rating 1200-1800, popularity >= 90"
pagination "page 1" \
	"SELECT * FROM puzzles WHERE rating >= 1200 AND rating <= 1800 AND popularity >= 90 LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles WHERE rating >= 1200 AND rating <= 1800 AND popularity >= 90;"
pagination "sort by rating ASC" \
	"SELECT * FROM puzzles WHERE rating >= 1200 AND rating <= 1800 AND popularity >= 90 ORDER BY rating ASC LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles WHERE rating >= 1200 AND rating <= 1800 AND popularity >= 90;"
