group "themes: fork + pin"
pagination "page 1" \
	"SELECT * FROM puzzles WHERE list_contains(themes, 'fork') AND list_contains(themes, 'pin') LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles WHERE list_contains(themes, 'fork') AND list_contains(themes, 'pin');"

group "themes: fork + short"
pagination "page 1" \
	"SELECT * FROM puzzles WHERE list_contains(themes, 'fork') AND list_contains(themes, 'short') LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles WHERE list_contains(themes, 'fork') AND list_contains(themes, 'short');"
