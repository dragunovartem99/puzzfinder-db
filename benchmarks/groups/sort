group "sort by rating"
pagination "ASC" \
	"SELECT * FROM puzzles ORDER BY rating ASC LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles;"
pagination "DESC" \
	"SELECT * FROM puzzles ORDER BY rating DESC LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles;"

group "sort by popularity"
pagination "DESC" \
	"SELECT * FROM puzzles ORDER BY popularity DESC LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles;"

group "sort by nbPlays"
pagination "DESC" \
	"SELECT * FROM puzzles ORDER BY nbPlays DESC LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles;"

group "sort by movesNumber"
pagination "ASC" \
	"SELECT * FROM puzzles ORDER BY movesNumber ASC LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles;"
