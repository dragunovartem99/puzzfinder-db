#!/bin/bash

group_header "search: themes: fork + pin (multi-theme, same column)"
benchmark "search: themes: fork + pin" "page 1" \
	"SELECT * FROM puzzles WHERE (theme_bits_a & $FORK_PIN_MASK) = $FORK_PIN_MASK LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles WHERE (theme_bits_a & $FORK_PIN_MASK) = $FORK_PIN_MASK;"

group_header "search: themes: fork + short (multi-theme, cross-column)"
benchmark "search: themes: fork + short" "page 1" \
	"SELECT * FROM puzzles WHERE (theme_bits_a & $FORK_MASK) = $FORK_MASK AND (theme_bits_b & $SHORT_MASK) = $SHORT_MASK LIMIT 20 OFFSET 0;" \
	"SELECT COUNT(*) FROM puzzles WHERE (theme_bits_a & $FORK_MASK) = $FORK_MASK AND (theme_bits_b & $SHORT_MASK) = $SHORT_MASK;"
